# ====== 嗅覺島 SOULAND 後端設定 ======
# 複製本檔為 .env 後填入。未設定者使用預設（綠界測試特店 + 僅本機備份）。

PORT=3000

# 對外可達的網址（部署/用 ngrok 時填；本機測試可留空，預設 http://localhost:PORT）
# 綠界 server-to-server 通知 (ReturnURL) 需此網址可被外網存取
PUBLIC_BASE_URL=

# ====== 綠界 ECPay ======
# 預設為綠界「公開測試特店」(STAGE)，可端對端跑通、不會真實扣款。
# 正式上線時改為你的正式特店資料，並把 ECPAY_API_URL 換成正式網址。
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cgi/AioCheckOut/V5
# 正式： https://payment.ecpay.com.tw/Cgi/AioCheckOut/V5

# ====== Google Sheet 報名回寫 ======
# 貼上 apps-script/Code.gs 部署後得到的 Web App /exec 網址。
# 留空 = 僅寫入本機 registrations.json。
REGISTRATION_WEBHOOK_URL=

# 後台查詢金鑰（/api/registrations?key=...），留空則不設限
ADMIN_KEY=

# ====== Admin 後台（/admin.html）參展廠商管理登入 ======
# 操作人員登入帳密。未設定使用預設 admin / souland2026（上線請務必修改）。
ADMIN_USER=admin
ADMIN_PASS=souland2026
# token 簽章密鑰，上線請改成隨機長字串
ADMIN_SECRET=change-me-to-a-long-random-string
